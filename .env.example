# DeerFlow environment variables for mac-server.local
# Copy to .env and fill in values (NEVER commit .env)

# Claude OAuth token (from 1Password: "Deer flow claude auth token")
ANTHROPIC_API_KEY=sk-ant-oat01-...
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# GitHub token (for GitHub MCP server tool)
GITHUB_TOKEN=ghp_...

# Telegram bot token (same bot OpenClaw uses — from Dokploy agentopia env)
TELEGRAM_BOT_TOKEN=

# DeerFlow runtime paths (set these to actual host paths)
DEER_FLOW_HOME=/opt/deerflow/data
DEER_FLOW_CONFIG_PATH=/opt/deerflow/config/config.yaml
DEER_FLOW_EXTENSIONS_CONFIG_PATH=/opt/deerflow/config/extensions_config.json
DEER_FLOW_DOCKER_SOCKET=/var/run/docker.sock
DEER_FLOW_REPO_ROOT=/opt/deerflow/app

# Auth secret for frontend sessions (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=

# Port for nginx (internal, before Caddy reverse-proxy)
PORT=2026
